# =============================================================================
# CRAFTY GIS — Root .gitignore
# Monorepo: Python backend + Next.js frontend + infrastructure + tooling
# =============================================================================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
*.so
.eggs/
*.whl
*.manifest
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
.env/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
test-reports/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# =============================================================================
# Node.js / JavaScript / TypeScript
# =============================================================================
node_modules/
.next/
out/
dist/
build/
.cache/
.eslintcache
.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
*.code-workspace
.idea/
*.iml
*.iws
*.swp
*.swo
*~
*.[0-9]
.vim/

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Data & Outputs (keep directory structure)
# =============================================================================
data/downloads/*
data/outputs/*
data/uploads/*
data/temp/*
data/projects/*
!data/downloads/.gitkeep
!data/outputs/.gitkeep
!data/uploads/.gitkeep
!data/temp/.gitkeep
!data/projects/.gitkeep

# Raster processing intermediates
*.aux.xml
*.ovr
*.msk

# =============================================================================
# Docker
# =============================================================================
.docker/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# Documentation generated files
# =============================================================================
docs/_build/
docs/build/

# =============================================================================
# Tauri (Desktop app)
# =============================================================================
src-tauri/target/
src-tauri/gen/
desktop/
build_exe.py
build-frontend.js
versions/

# =============================================================================
# Binary files & large artifacts
# =============================================================================
*.db
*.sqlite
*.sqlite3
GIT_STAR/xlsx/scripts/Xlsx
GIT_STAR/docx/validator/DocumentFormat.OpenXml.dll
GIT_STAR/*.docx
GIT_STAR/*.png
GIT_STAR/*.gif
GIT_STAR/*.tif
GIT_STAR/*.tiff
GIT_STAR/*.geojson
GIT_STAR/assignment_images/
GIT_STAR/data_run/

# =============================================================================
# Graphify & agent memory
# =============================================================================
graphify-out/
.agent/memory/
git_star_gains/

# =============================================================================
# Virtual environments & binaries
# =============================================================================
testenv/
*.pyvenv
*.pyc

# =============================================================================
# Misc
# =============================================================================
*.bak
*.tmp
*.zip
*.tar.gz
.vite/
claude/
.claude/
