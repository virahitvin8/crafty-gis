{
  "productName": "CRAFTY GIS",
  "version": "1.0.0",
  "identifier": "com.craftygis.app",
  "build": {
    "frontendDist": "../../crafty-gis-client/.next",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../crafty-gis-client && npm run dev",
    "beforeBuildCommand": "cd ../crafty-gis-client && npm run build"
  },
  "app": {
    "title": "CRAFTY GIS — Conversational Remote Analysis & Field Technology for GIS",
    "windows": [
      {
        "title": "CRAFTY GIS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
