# CRAFTY GIS — Comprehensive .gitignore
# Monorepo: Python backend + Next.js frontend + infrastructure

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
*.so
.eggs/
*.whl
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
.env/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
test-reports/

# Mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# =============================================================================
# Node.js / JavaScript / TypeScript
# =============================================================================
# Dependencies
node_modules/

# Build outputs
.next/
out/
dist/
build/

# Cache
.cache/
.eslintcache
.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# IDE & Editor
# =============================================================================
# VS Code
.vscode/
*.code-workspace

# JetBrains (IntelliJ, PyCharm, WebStorm)
.idea/
*.iml
*.iws
out/

# Vim / NeoVim
*.swp
*.swo
*~
*.un~
*.[0-9]
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
.elisp-autofrly
.\#*

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Data & Outputs (keep directory structure)
# =============================================================================
data/downloads/*
data/outputs/*
data/uploads/*
data/temp/*
data/projects/*
!data/downloads/.gitkeep
!data/outputs/.gitkeep
!data/uploads/.gitkeep
!data/temp/.gitkeep
!data/projects/.gitkeep

# Raster processing intermediates
*.aux.xml
*.ovr
*.msk

# =============================================================================
# Docker
# =============================================================================
.docker/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# Documentation generated files
# =============================================================================
docs/_build/
docs/build/

# =============================================================================
# Tauri (Desktop app)
# =============================================================================
src-tauri/target/
src-tauri/gen/

# =============================================================================
# Misc
# =============================================================================
*.bak
*.tmp
*.swp
.DS_Store
