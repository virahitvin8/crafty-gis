# CRAFTY GIS Backend — Environment Configuration
# Copy this to .env and modify as needed

# Application
APP_NAME=CRAFTY GIS
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Database (PostgreSQL + PostGIS)
# Default: SQLite (no config needed)
# For PostGIS: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/crafty_gis
DATABASE_URL=

# Ollama / Local LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Data Directories (defaults to ./data if not set)
DATA_DIR=
