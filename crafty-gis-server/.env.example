# ============================================================
# CRAFTY GIS — Server Configuration
# Copy this to .env and fill in your values
# THIS FILE IS SAFE TO SHARE — no real secrets here
# ============================================================

# Application
APP_NAME=CRAFTY GIS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# CORS — Frontend URLs allowed to talk to backend
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# Database — SQLite (default) or PostgreSQL (production)
# SQLite (easy, no install):
DATABASE_URL=sqlite+aiosqlite:///./crafty_gis.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://crafty:crafty_secret@localhost:5432/crafty_gis
DB_ECHO=false

# Data Directory (where downloaded files & outputs are saved)
DATA_DIR=./data

# ============================================================
# AI / LLM Configuration
# ============================================================

# PRIMARY: Groq AI (fast, free tier, no local install needed)
# Get your key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# FALLBACK: Ollama (local, private, works offline)
# Install: https://ollama.ai | Run: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# GEMINI (optional, alternative)
GEMINI_API_KEY=

# ============================================================
# Satellite Data Source APIs
# ============================================================

# Copernicus / ESA (Sentinel-1, Sentinel-2 data)
# Register at: https://dataspace.copernicus.eu
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# NASA Earthdata (MODIS, SRTM, GEDI, ICESat data)
# Register at: https://urs.earthdata.nasa.gov
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=

# USGS EarthExplorer (Landsat data)
# Register at: https://earthexplorer.usgs.gov
USGS_USERNAME=
USGS_PASSWORD=
USGS_API_KEY=

# Bhoonidhi (India — ISRO satellite data portal)
# Register at: https://bhoonidhi.nrsc.gov.in
BHOONIDHI_USERNAME=
BHOONIDHI_PASSWORD=

# Survey of India Open Maps Portal
SOI_PHONE=
SOI_PASSWORD=
